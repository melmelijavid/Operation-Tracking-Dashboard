# Port the Express server listens on.
PORT=3001

# Postgres connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/operation_tracking_dashboard

# Secret used to sign JWTs. Must be at least 32 characters and not a placeholder.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Origin allowed by CORS. Should match your client dev URL.
CORS_ORIGIN=http://localhost:5173

# ─── Email (verification codes) ──────────────────────────────────────────
# In dev, leave SMTP_HOST blank — the server auto-creates an Ethereal test
# account on first send and prints a preview URL to the console.
# In production, fill these in (Gmail app password, SendGrid, Mailgun, SES…).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Operation Tracking <no-reply@operationtracking.local>"
